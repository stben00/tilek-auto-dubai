# Telegram
BOT_TOKEN=
ADMIN_TELEGRAM_IDS=

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=stben00
GITHUB_REPO=tilek-auto-dubai
GITHUB_BRANCH=main
CARS_JSON_PATH=cars.json
IMAGES_FOLDER=assets/cars
VIDEOS_FOLDER=assets/videos

# AI (optional, leave empty to use regex parser only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Website
WEBSITE_URL=https://stben00.github.io/tilek-auto-dubai/

# Video size limit in MB for GitHub upload (default 20)
MAX_VIDEO_MB=20

# AI features (OPTIONAL — bot works fully without these)
ENABLE_AI_TEXT=true
ENABLE_AI_IMAGE=false       # leave OFF — bot uses free local PIL poster instead

# Local ad-poster generator (free, no API)
ENABLE_LOCAL_POSTER=true
POSTER_SIZE=1080x1350       # also try 1080x1920 for Stories

# Optional / placeholder for future
SITE_API_URL=
ADMIN_TELEGRAM_ID=
MEDIA_STORAGE_PATH=
